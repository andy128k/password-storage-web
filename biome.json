{
  "$schema": "https://biomejs.dev/schemas/2.4.2/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git"
  },
  "files": {
    "ignoreUnknown": false,
    "includes": ["**", "!coverage", "!dist", "!public"]
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noUselessElse": "off",
        "useTemplate": "off"
      },
      "a11y": {
        "useHtmlLang": "warn",
        "noStaticElementInteractions": "warn"
      }
    }
  },
  "javascript": {
    "jsxRuntime": "reactClassic"
  }
}
